# Codex Reader local runtime
CODEX_READER_HOST=127.0.0.1
CODEX_READER_PORT=3001

# Keep runtime data outside Dropbox in production.
# macOS default: ~/Library/Application Support/CodexReader
# For local development you can use: ./.runtime
CODEX_READER_HOME=

# Comma-separated browser origins allowed to call the API.
# Leave empty for same-origin local use.
CODEX_READER_CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# Optional internal API token for direct API calls.
# If set, clients must send X-Codex-Reader-Token.
CODEX_READER_API_TOKEN=

# auto tries Codex CLI and falls back to local deterministic analysis.
# live fails jobs when Codex CLI fails. mock never calls Codex.
CODEX_READER_CODEX_MODE=auto
CODEX_READER_CODEX_TIMEOUT_MS=120000

# Upload safety
CODEX_READER_MAX_UPLOAD_MB=50

# Cloudflare Access JWT validation is normally enforced at the edge.
# Set this only after configuring Access audience/issuer checks.
CODEX_READER_REQUIRE_ACCESS_JWT=false

# Cloudflare Tunnel
# Created tunnel: codex-reader / 7b63dd79-b0f5-410c-a5f1-16f3b86e7ca2
CODEX_READER_TUNNEL_ID=7b63dd79-b0f5-410c-a5f1-16f3b86e7ca2
CODEX_READER_TUNNEL_URL=https://reader-api.futurecontext.net
CODEX_READER_PAGES_URL=https://pdf-study.pages.dev
